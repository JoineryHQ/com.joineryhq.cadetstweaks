<?xml version="1.0"?>
<extension key="com.joineryhq.cadetstweaks" type="module">
  <file>cadetstweaks</file>
  <name>Cadets Tweaks</name>
  <description>CiviCRM customizations for The Cadets</description>
  <license>GPL-3.0</license>
  <maintainer>
    <author>https://github.com/JoineryHQ/</author>
    <email>info@JoineryHQ.com</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://github.com/JoineryHQ/com.joineryhq.cadetstweaks</url>
    <url desc="Documentation">https://github.com/JoineryHQ/com.joineryhq.cadetstweaks</url>
    <url desc="Support">https://github.com/JoineryHQ/com.joineryhq.cadetstweaks/issues</url>
    <url desc="Licensing">http://www.gnu.org/licenses/gpl-3.0.html</url>
  </urls>
  <releaseDate>2021-12-13</releaseDate>
  <version>1.0.5</version>
  <develStage>beta</develStage>
  <compatibility>
    <ver>5.51</ver>
  </compatibility>
  <comments>Developed by Joinery for The Cadets</comments>
  <classloader>
    <psr4 prefix="Civi\" path="Civi"/>
    <psr0 prefix="CRM_" path="."/>
  </classloader>
  <civix>
    <namespace>CRM/Cadetstweaks</namespace>
    <format>25.10.2</format>
  </civix>
  <mixins>
    <mixin>mgd-php@2.0.0</mixin>
    <mixin>scan-classes@1.0.0</mixin>
  </mixins>
  <upgrader>CiviMix\Schema\Cadetstweaks\AutomaticUpgrader</upgrader>
</extension>
